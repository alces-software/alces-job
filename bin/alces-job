#!/usr/bin/env ruby
# frozen_string_literal: true

root = File.expand_path('..', __dir__)
require "#{root}/lib/cli/cli"

begin
  Dry::CLI.new(AlcesJob::CLI).call
rescue ArgumentError => e
  if (match = e.message.match(/missing keyword: :(\w+)/))
    missing = match[1]
    warn Pastel.new.red("\nMissing required argument: #{missing}\n")
  end
  exit(1)
rescue StandardError => e
  warn Pastel.new.red("\nAn error occurred while calling the command.")
  warn Paste.red("#{e.message}\n")
  exit(1)
end
