#!/bin/bash
#SBATCH --job-name=mega_pipeline                       # Name shown for this job in the Slurm queue
#SBATCH --nodes=1                                      # Number of nodes/machines requested
#SBATCH --ntasks=32                                    # Number of tasks/processes to run
#SBATCH --cpus-per-task=8                              # CPU cores available to each task
#SBATCH --mem=6G                                       # Amount of memory requested for the job
#SBATCH --time=2-00:00:00                              # Maximum runtime before Slurm stops the job
#SBATCH --partition=gpu                                # Partition/queue where the job should run
#SBATCH --account=research_allocation                  # Account/project to charge the job to
#SBATCH --gres=gpu:4                                   # Generic resources, commonly used for GPUs, e.g. gpu:1
#SBATCH --mail-user=you@example.com                    # Email address for Slurm job notifications
#SBATCH --mail-type=ALL                                # When to send emails, e.g. BEGIN, END, FAIL, ALL
#SBATCH --array=1-100%10                               # Run as an array job; each task gets a SLURM_ARRAY_TASK_ID
#SBATCH --dependency=afterok:123456                    # Start this job only after another job condition is met
#SBATCH --output=%x-%j.out
#SBATCH --error=%x-%j.err

module purge
module load python/3.11                                # Load required software/module before running
module load cuda/12.2                                  # Load required software/module before running
module load openmpi/4.1                                # Load required software/module before running
module load samtools/1.18                              # Load required software/module before running

cd /home/calummurphy/projects/mega_pipeline            # Move to the working directory

alces_prepare_job() {
  job_dir="$HOME/${SLURM_JOB_NAME}-${SLURM_JOB_ID}"

  if [ -n "$SLURM_ARRAY_TASK_ID" ]; then
    job_dir="${job_dir}-${SLURM_ARRAY_TASK_ID}"
  fi

  mkdir -p "$job_dir"
  cd "$job_dir" || exit 1
}

alces_prepare_job

alces_setup_local_scratch() {
  if [ "${SLURM_JOB_NUM_NODES:-1}" -gt 1 ]; then
    echo "Local scratch is only supported for single-node jobs." >&2
    exit 1
  fi

  scratch_dir="/scratch/local/$USER/${SLURM_JOB_NAME}-${SLURM_JOB_ID}"
  result_dir="$HOME/${SLURM_JOB_NAME}-${SLURM_JOB_ID}"

  mkdir -p "$scratch_dir"
  mkdir -p "$result_dir"

  cp -a "$SLURM_SUBMIT_DIR"/. "$scratch_dir"/

  cd "$scratch_dir" || exit 1
}

alces_copy_results_back() {
  exit_status=$?

  cp -a "$scratch_dir"/. "$result_dir"/
  rm -rf "$scratch_dir"

  return "$exit_status"
}

alces_setup_local_scratch
trap alces_copy_results_back EXIT

echo "Running job"                                                    # Print which job is running
srun python train_and_analyse.py --array-id "$SLURM_ARRAY_TASK_ID" --epochs 200# Run the user's command

