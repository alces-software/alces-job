#!/bin/bash

<%- line = "#SBATCH --job-name=#{@context.job_name}" -%>
<%= line.ljust(50) %># Name shown for this job in the Slurm queue
<%- line = "#SBATCH --array=#{@context.array}" -%>
<%= line.ljust(50) %># Run as an array job; each task gets its own SLURM_ARRAY_TASK_ID
<% if @context.partition -%>
<%- line = "#SBATCH --partition=#{@context.partition}" -%>
<%= line.ljust(50) %># Partition/queue where the job should run
<% end -%>
<% if @context.output -%>
<%- line = "#SBATCH --output=#{@context.output}" -%>
<%= line.ljust(55) %># Output file of the slurm job
<% end -%>
<% if @context.error -%>
<%- line = "#SBATCH --error=#{@context.error}" -%>
<%= line.ljust(55) %># Error file of the slurm job
<% end -%>
<% if @context.account -%>
<%- line = "#SBATCH --account=#{@context.account}" -%>
<%= line.ljust(55) %># Account/project to charge the job to
<% end -%>
<% if @context.time -%>
<%- line = "#SBATCH --time=#{@context.time}" -%>
<%= line.ljust(50) %># Maximum runtime before Slurm stops the job
<% end -%>
<% if @context.mem -%>
<%- line = "#SBATCH --mem=#{@context.mem}" -%>
<%= line.ljust(50) %># Amount of memory requested for the job
<% end -%>
<% if @context.prepare -%>
<%= @prepare.directives %>
<% end -%>
<% unless Array(@context.modules).empty? -%>
module purge
<% end -%>
<% Array(@context.modules).each do |mod| -%>
<%- line = "module load #{mod}" -%>
<%= line.ljust(50) %># Load required software/module before running
<% end -%>
<% if @context.track %>
# Tracking Functions:
<%= "source #{@context.tracking_path}" %>
<%= "export ALCES_HOMEPATH=#{@context.job_path}" %>
export ALCES_TOTAL_STAGES=1

alces_start_job

alces_start_stage
<% end %>
<% if @context.workdir -%>
<%- line = "cd #{@context.workdir}" -%>
<%= line.ljust(50) %># Move to the working directory
<% end -%>
<% if @context.prepare -%>
<%= @prepare.helper %>
<% end -%>
<% if @context.local_scratch -%>
<%= @local_scratch.helper(scratch_path: @context.scratch_path) %>
<% elsif @context.prepare -%>
<%= @prepare.helper %>
<% end -%>
<%- line = 'echo "Task ID: $SLURM_ARRAY_TASK_ID"' -%>
<%= line.ljust(50) %># Print this array task's ID
<%- line = @context.command || "echo 'No command provided'" -%>
<%= line.ljust(70) %># Run the user's command
<% if @context.track %>

alces_end_stage
<% end %>
