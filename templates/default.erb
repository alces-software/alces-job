#!/bin/bash
<% if @context.job_name -%>
#SBATCH --job-name=<%= @context.job_name %>
<% end -%>
<% if @context.nodes -%>
#SBATCH --nodes=<%= @context.nodes %>
<% end -%>
<% if @context.ntasks -%>
#SBATCH --ntasks=<%= @context.ntasks %>
<% end -%>
<% if @context.cpus_per_task -%>
#SBATCH --cpus-per-task=<%= @context.cpus_per_task %>
<% end -%>
<% if @context.mem -%>
#SBATCH --mem=<%= @context.mem %>
<% end -%>
<% if @context.time -%>
#SBATCH --time=<%= @context.time %>
<% end -%>
<% if @context.partition -%>
#SBATCH --partition=<%= @context.partition %>
<% end -%>
<% if @context.account -%>
#SBATCH --account=<%= @context.account %>
<% end -%>
<% if @context.gres -%>
#SBATCH --gres=<%= @context.gres %>
<% end -%>
<% if @context.mail_user -%>
#SBATCH --mail-user=<%= @context.mail_user %>
<% end -%>
<% if @context.mail_type -%>
#SBATCH --mail-type=<%= @context.mail_type %>
<% end -%>
<% if @context.array -%>
#SBATCH --array=<%= @context.array %>
<% end -%>
<% if @context.dependency -%>
#SBATCH --dependency=<%= @context.dependency %>
<% end -%>
<% Array(@context.modules).each do |mod| -%>
module load <%= mod %>
<% end -%>
<% if @context.workdir -%>
cd <%= @context.workdir %>
<% end -%>

echo "Running job<% if @context.job_name %>: '<%= @context.job_name %>'<% end %>"

<%= @context.command || "echo 'No command provided'" %>