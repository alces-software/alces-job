#!/bin/bash

# Slurm options: request multiple tasks/nodes for a distributed MPI job.
#SBATCH --job-name=<%= @context.job_name %>
#SBATCH --nodes=<%= @context.nodes || 2 %>
#SBATCH --ntasks=<%= @context.ntasks || 32 %>
#SBATCH --cpus-per-task=<%= @context.cpus_per_task || 1 %>
<% if @context.partition -%>
#SBATCH --partition=<%= @context.partition %>
<% end -%>
<% if @context.time -%>
#SBATCH --time=<%= @context.time %>
<% else -%>
#SBATCH --time=02:00:00
<% end -%>
<% if @context.mem -%>
#SBATCH --mem=<%= @context.mem %>
<% end -%>

# Load MPI first, then any extra modules requested by the user.
module load openmpi
<% Array(@context.module).each do |mod| -%>
module load <%= mod %>
<% end -%>
<% if @context.workdir -%>

# Run the job from this working directory.
cd <%= @context.workdir %>

<% end -%>
# Show how many MPI tasks Slurm assigned.
echo "Running MPI job on $SLURM_NTASKS tasks across $SLURM_NNODES nodes"

# Launch the MPI workload through Slurm.
srun <%= @context.command %>
