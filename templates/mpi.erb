#!/bin/bash
<%- line = "#SBATCH --job-name=#{@context.job_name}" -%>
<%= line.ljust(50) %># Name shown for this job in the Slurm queue
<%- line = "#SBATCH --nodes=#{@context.nodes || 2}" -%>
<%= line.ljust(50) %># Number of nodes/machines requested
<%- line = "#SBATCH --ntasks=#{@context.ntasks || 1}" -%>
<%= line.ljust(50) %># Total number of MPI tasks/processes
<%- line = "#SBATCH --cpus-per-task=#{@context.cpus_per_task || 1}" -%>
<%= line.ljust(50) %># CPU cores per MPI task
<% if @context.partition -%>
<%- line = "#SBATCH --partition=#{@context.partition}" -%>
<%= line.ljust(50) %># Partition/queue where the job should run
<% end -%>
<% if @context.account -%>
  <%- line = "#SBATCH --account=#{@context.account}" -%>
  <%= line.ljust(55) %># Account/project to charge the job to
<% end -%>
<% if @context.time -%>
<%- line = "#SBATCH --time=#{@context.time}" -%>
<%= line.ljust(50) %># Maximum runtime before Slurm stops the job
<% end -%>
<% if @context.mem -%>
<%- line = "#SBATCH --mem=#{@context.mem}" -%>
<%= line.ljust(50) %># Amount of memory requested for the job
<% end -%>
<% if @context.prepare -%>
<%= @prepare.directives %>
<% end -%>
<%- line = "module purge" -%>
<%- line = "module load openmpi" -%>
<%= line.ljust(50) %># Load OpenMPI so MPI programs can run
<% Array(@context.modules).each do |mod| -%>
<%- line = "module load #{mod}" -%>
<%= line.ljust(50) %># Load extra user-requested module
<% end -%>
<% if @context.track %>
# Tracking Functions:
<%= "source #{@context.tracking_path}" %>
<%= "export ALCES_HOMEPATH=#{@context.job_path}" %>
export ALCES_TOTAL_STAGES=0

<%= "alces_start_job" %>
<% end %>
<% if @context.workdir -%>
<%- line = "cd #{@context.workdir}" -%>
<%= line.ljust(50) %># Move to the working directory
<% end -%>

<% if @context.local_scratch -%>
<%= @local_scratch.helper(scratch_path: @context.scratch_path) %>
<% elsif @context.prepare -%>
<%= @prepare.helper %>
<% end -%>
<%- line = 'echo "Running MPI job on $SLURM_NTASKS tasks across $SLURM_NNODES nodes"' -%>
<%= line.ljust(80) %># Print MPI resource information
<%- line = @context.command || "echo 'No command provided'" -%>
<%= line.ljust(50) %># Launch the MPI program using Slurm's task launcher
